modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["glib", "nss", "nspr", "atk", "at-spi2-atk", "libdrm", "mesa", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libxcb", "xorg.libxshmfence", "libxkbcommon", "pango", "cairo", "at-spi2-core", "cups", "dbus-glib", "expat", "gtk3", "xorg.libXScrnSaver", "alsa-lib", "xorg.libXtst", "xorg.libXcursor", "xorg.libXi", "xorg.libXrender", "xorg.libXft", "xorg.libXinerama", "xorg.libXpm", "xorg.libXaw", "xorg.libXmu", "xorg.libXres", "xorg.libXdmcp", "xorg.libXau", "gdk-pixbuf", "fontconfig", "freetype", "harfbuzz", "icu", "libpng", "libjpeg_turbo", "libwebp", "libtiff", "zlib", "libsecret", "libnotify", "libgbm"]

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application (Electron)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start application (Electron)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev:electron"

[workflows.workflow.metadata]
outputType = "vnc"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3001
